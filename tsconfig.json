{
  "compilerOptions": {
    "types": ["node","jest"],
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "strict": false,
    "sourceMap": true,
    "declaration": true,
    "experimentalDecorators": true, 
    "emitDecoratorMetadata": true,
    "outDir": "dist",
    "rootDir": "src",
  },
  "include": ["src/**/*.ts"], 
  "exclude": ["src/**/*.test.ts"]
}
